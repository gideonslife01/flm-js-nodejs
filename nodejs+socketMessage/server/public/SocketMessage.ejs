<!DOCTYPE html>
<html>
<head>
  <title>Socket.IO 웹 클라이언트</title>
  <style>
    /* 스타일링 */
    body { font-family: sans-serif; margin: 20px; }
    #messages { border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; height: 200px; overflow-y: scroll; }
    input[type="text"] { width: 80%; padding: 8px; margin-right: 10px; }
    button { padding: 8px 15px; }
  </style>
</head>
<body>
  <% if (locals.userid) { %>
    <h1>Socket.IO 웹 클라이언트 / Socket.IO Web Client</h1>
    <div id="messages">
      <p>받은 메시지/Received Message:</p>
    </div>
    <div>
      <input type="text" id="messageInput" placeholder="메시지를 입력하세요./Please enter your message">
      <button onclick="sendMessage()">보내기/Send</button>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
      const socket = io('http://192.168.0.10:3000'); // 서버 주소 : Server address

      const messagesDiv = document.getElementById('messages');
      const messageInput = document.getElementById('messageInput');

      socket.on('connect', () => {
        console.log('server is connected');
      });

      socket.on('disconnect', () => {
        console.log('server is disconnected');
      });

      socket.on('serverMessage', (data) => {
        const newMessage = document.createElement('p');
        newMessage.textContent = data.text;
        messagesDiv.appendChild(newMessage);
        messagesDiv.scrollTop = messagesDiv.scrollHeight; // 스크롤 아래로 이동 : scroll down
      });

      async function sendMessage() {
        let user = '<%= locals.name %>'; // users name
        const message = messageInput.value;
        if (message) {
          const messageToSend = `${user}:${message}`;
          socket.emit('clientMessage', { text: messageToSend });
          messageInput.value = '';
        } else if (!user) {
          console.warn('사용자 정보가 없습니다.There is no user information.');
        }
      }

      // 엔터 키 입력 시 메시지 전송 기능 추가
      messageInput.addEventListener('keypress', function(event) {
        if (event.key === 'Enter') {
          sendMessage();
          event.preventDefault(); // 기본 엔터 동작 (새 줄 추가) 방지
        }
      });

      // (선택 사항) 페이지 로드 시 사용자 정보 표시 예시
      window.onload = () => {
        const loggedInUser = '<%= locals.name %>';
        if (loggedInUser) {
          console.log('로그인된 사용자/Logged in user:', loggedInUser);
          // 환영 메시지
          //messagesDiv.append(`==>${loggedInUser}님 입장`);
          //messagesDiv.appendChild(`gkdl`);
        }
      };
    </script>
  <% } else { %>
    <a href="/login">로그인/Log in</a>
  <% } %>
</body>
</html>